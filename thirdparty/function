# downlaod https://www.openssl.org/source/openssl-3.1.4.tar.gz
function download ()
{
    if [ $# -gt 0 ]; then
        local download_url=$1
        local tarball=`basename $download_url`
        if [ ! -f $tarball ]; then
            wget --no-check-certificate $download_url
        fi
    fi
}

function filename ()
{
    echo $1 | sed 's/\r//g' | sed 's/\(.*\)\(.tar.gz\|.tgz\|.tar.bz2\|.zip\)/\1/'
}

# inflate filename
function inflate ()
{
    if [ $# -gt 0 ]; then
        local tarball=`basename $1`

        local filename=`echo $1 | sed 's/\r//g' | sed 's/\(.*\)\(.tar.gz\|.tgz\|.tar.bz2\|.zip\)/\1/'`
        local ext=`echo $tarball | sed 's/\r//g' | sed 's/\(.*\)\(.tar.gz\|.tgz\|.tar.bz2\|.zip\)/\2/'`
        if [ ! -d $filename ]; then
            case $ext in
              .tar.gz)
                tar xvfz $tarball
                ;;
              .tgz)
                tar xvfz $tarball
                ;;
              .tar.bz2)
                tar xvfj $tarball
                ;;
              .zip)
                unzip $tarball
                ;;
            esac
        fi
    fi
}

# build_openssl directory
function build_openssl ()
{
    if [ ${base} = "msvc" ]; then
        echo 'install Visual Studio Community (latest free version https://visualstudio.microsoft.com/ko/vs/community/)'
        echo 'install Perl for MS Windows (https://strawberryperl.com/)'
        echo 'run cmd'
        echo '> cd "'$(cygpath -w $(pwd))'"'
        echo '> "c:\Program Files\Microsoft Visual Studio\18\Community\VC\Auxiliary\Build\vcvars64.bat"'
        echo '> perl Configure VC-WIN64A --prefix="'$(cygpath -w ${install_dir})'" --with-rand-seed=os no-egd -d shared'
        echo '> nmake'
        echo '> nmake install_sw install_ssldirs'
        return 0
    fi

    if [[ $OSTYPE = "cygwin" || $OSTYPE = "msys" ]]; then
        ./Configure mingw64 --prefix=${install_dir} --with-rand-seed=os no-egd -d shared
    else
        ./Configure linux-x86_64 --prefix=${install_dir} --with-rand-seed=devrandom -D__USE_UNIX98=1 -D_GNU_SOURCE=1 no-egd -d shared
    fi

    make -j 2
    touch crypto/rand/drbg_ctr.c
    make -j 2
    make -j 2 install_sw install_ssldirs

    mkdir -p ${builddir}
    touch ${builddir}/.complete
}

# build_jansson directory
function build_jansson ()
{
    cmake -G "${generator}" --install-prefix ${install_dir} -B $builddir -DCMAKE_BUILD_TYPE=${target} -DJANSSON_BUILD_DOCS=OFF
    cd $builddir
    cmake --build . --config ${target}
    cmake --install . --config ${target}

    touch .complete
}

